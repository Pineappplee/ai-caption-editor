# ─────────────────────────────────────────────────────
# AI Caption Editor – Backend Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────
DB_NAME=ai_caption_editor
DB_USER=postgres
DB_PASSWORD=change_me_in_production          # REQUIRED – use a strong password
DB_EXTERNAL_PORT=5433                         # Host port mapped to Postgres container

# ── JWT Authentication ────────────────────────────────
# Generate with: openssl rand -base64 64
APP_JWT_SECRET=                               # REQUIRED – must be at least 256 bits (43+ base64 chars)
APP_JWT_EXPIRATION_MS=900000                  # Access token TTL (default: 15 minutes)
APP_JWT_REFRESH_EXPIRATION_MS=604800000       # Refresh token TTL (default: 7 days)

# ── Spring Profile ────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev                    # Use 'prod' for production

# ── AI Provider ───────────────────────────────────────
# Options: mock | ollama | openrouter
AI_PROVIDER=mock

# Ollama (local LLM – no API key needed)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenRouter (cloud LLM – requires API key)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free

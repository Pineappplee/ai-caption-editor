# Service Mode
# Set to 'mock' to use local mock data (no backend required)
# Set to 'http' to connect to the Spring Boot backend
VITE_SERVICE_MODE=http

# Backend API URL (only used when VITE_SERVICE_MODE=http)
VITE_API_URL=http://localhost:8080

# Whether the application requires authentication in HTTP mode
VITE_REQUIRE_AUTH=true
